    <worksheet name='Overview Sheet 7'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='12'>Customer Retention</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bus_booking_tableau' name='federated.1y61ql410mslgw1gnubr30hxnqf6' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Month' datatype='date' name='[Parameter 2285907838521372]' param-domain-type='range' role='measure' type='quantitative' value='#2026-07-14#'>
              <calculation class='tableau' formula='#2026-07-14#' />
              <range max='#2026-11-07#' min='#2025-01-01#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1y61ql410mslgw1gnubr30hxnqf6'>
            <column caption='Booking Date' datatype='date' name='[Booking_Date]' role='dimension' type='ordinal' />
            <column caption='Booking ID' datatype='integer' name='[Booking_ID]' role='dimension' type='ordinal' />
            <column caption=' Customer Retention Rate' datatype='real' name='[Calculation_2285907836186630]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF { FIXED [Customer_ID] : COUNT([Booking_ID]) } &gt; 1 THEN [Customer_ID] END) &#13;&#10;/ &#13;&#10;COUNTD([Customer_ID])' />
            </column>
            <column caption='Current Month Retention Rate' datatype='real' name='[Calculation_2285908036395047]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : COUNTD(IF { FIXED [Customer_ID] : COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Booking_ID] END) } &gt; 1 THEN [Customer_ID] END) &#13;&#10;     / &#13;&#10;     COUNTD(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Customer_ID] END) }' />
            </column>
            <column caption='Previous Month Retention Rate' datatype='real' name='[Calculation_2285908036472872]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : COUNTD(IF { FIXED [Customer_ID] : COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Booking_ID] END) } &gt; 1 THEN [Customer_ID] END) &#13;&#10;     / &#13;&#10;     COUNTD(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Customer_ID] END) }' />
            </column>
            <column caption='Retention MoM %' datatype='real' name='[Calculation_2285908036575273]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_2285908036395047] - [Calculation_2285908036472872]) / [Calculation_2285908036472872]' />
            </column>
            <column aggregation='Sum' caption='Customer ID' datatype='integer' name='[Customer_ID]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_2285908036575273]' derivation='Sum' name='[sum:Calculation_2285908036575273:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2285907836186630]' derivation='User' name='[usr:Calculation_2285907836186630:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='table'>
            <format attr='background-color' value='#00000000' />
          </style-rule>
        </style>
        <panes>
