    <worksheet name='Overview Sheet 1'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='12'>Total Revenue</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bus_booking_tableau' name='federated.1y61ql410mslgw1gnubr30hxnqf6' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Month' datatype='date' name='[Parameter 2285907838521372]' param-domain-type='range' role='measure' type='quantitative' value='#2026-07-14#'>
              <calculation class='tableau' formula='#2026-07-14#' />
              <range max='#2026-11-07#' min='#2025-01-01#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1y61ql410mslgw1gnubr30hxnqf6'>
            <column caption='Booking Date' datatype='date' name='[Booking_Date]' role='dimension' type='ordinal' />
            <column caption='Total Revenue' datatype='real' name='[Calculation_2285907835625472]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount])' />
            </column>
            <column caption='Current Month Revenue' datatype='real' name='[Calculation_2285907838828573]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Fare_Amount] END) }' />
            </column>
            <column caption='Previous Month Revenue' datatype='real' name='[Calculation_2285907838926878]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Fare_Amount] END) }' />
            </column>
            <column caption='Revenue MoM %' datatype='real' name='[Calculation_2285907839029279]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_2285907838828573] - [Calculation_2285907838926878]) / [Calculation_2285907838926878]' />
            </column>
            <column caption='Fare Amount' datatype='real' name='[Fare_Amount]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2285907839029279]' derivation='Sum' name='[sum:Calculation_2285907839029279:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2285907835625472]' derivation='User' name='[usr:Calculation_2285907835625472:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
