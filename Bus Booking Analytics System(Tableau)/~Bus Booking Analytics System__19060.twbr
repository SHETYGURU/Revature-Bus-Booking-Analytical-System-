    <worksheet name='Sheet 23'>
      <table>
        <view>
          <datasources>
            <datasource caption='bus_booking_tableau' name='federated.1y61ql410mslgw1gnubr30hxnqf6' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Month' datatype='date' name='[Parameter 2285907838521372]' param-domain-type='range' role='measure' type='quantitative' value='#2026-07-14#'>
              <calculation class='tableau' formula='#2026-07-14#' />
              <range max='#2026-11-07#' min='#2025-01-01#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1y61ql410mslgw1gnubr30hxnqf6'>
            <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
            <column caption='Booking Date' datatype='date' name='[Booking_Date]' role='dimension' type='ordinal' />
            <column caption='Booking ID' datatype='integer' name='[Booking_ID]' role='dimension' type='ordinal' />
            <column caption='Booking Status' datatype='string' name='[Booking_Status]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Bus ID' datatype='integer' name='[Bus_ID]' role='dimension' type='ordinal' />
            <column caption='Total Revenue' datatype='real' name='[Calculation_2285907835625472]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount])' />
            </column>
            <column caption='Total Bookings' datatype='integer' name='[Calculation_2285907835752449]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Booking_ID])' />
            </column>
            <column caption='Average Fare' datatype='real' name='[Calculation_2285907835834370]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNT([Booking_ID])' />
            </column>
            <column caption='Lead Time Days' datatype='integer' name='[Calculation_2285907836002308]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Booking_Date], [Travel_Date])' />
            </column>
            <column caption='Average Lead Time' datatype='real' name='[Calculation_2285907836092421]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_2285907836002308])' />
            </column>
            <column caption=' Customer Retention Rate' datatype='real' name='[Calculation_2285907836186630]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF { FIXED [Customer_ID] : COUNT([Booking_ID]) } &gt; 1 THEN [Customer_ID] END) &#13;&#10;/ &#13;&#10;COUNTD([Customer_ID])' />
            </column>
            <column caption='Occupancy Rate' datatype='real' name='[Calculation_2285907836276743]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Booking_ID] END)&#13;&#10;/&#13;&#10;SUM({ FIXED [Travel_Date], [Bus_ID] : MAX([Capacity]) })' />
            </column>
            <column caption='Cancellation Rate' datatype='real' name='[Calculation_2285907836370952]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Cancelled&apos; THEN [Booking_ID] END) / COUNT([Booking_ID])' />
            </column>
            <column caption='Active Route Footprint' datatype='integer' name='[Calculation_2285907836579850]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Route_ID])' />
            </column>
            <column caption='Average Bus Capacity' datatype='real' name='[Calculation_2285907836948494]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Capacity])' />
            </column>
            <column caption='Avg Bookings per Customer' datatype='real' name='[Calculation_2285907837124624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Booking_ID]) / COUNTD([Customer_ID])' />
            </column>
            <column caption='Avg Spend per Customer' datatype='real' name='[Calculation_2285907837206545]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Customer_ID])' />
            </column>
            <column caption='Average Route Distance' datatype='real' name='[Calculation_2285907837423635]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Distance])' />
            </column>
            <column caption='Avg Route Yield' datatype='real' name='[Calculation_2285907837657110]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Route_ID])' />
            </column>
            <column caption='Avg Revenue per Day' datatype='real' name='[Calculation_2285907837751319]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Booking_Date])' />
            </column>
            <column caption='Average Confirmed Transaction Value' datatype='real' name='[Calculation_2285907837915161]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Fare_Amount] END) / COUNT(IF [Booking_Status] = &apos;Confirmed&apos; THEN [Booking_ID] END)' />
            </column>
            <column caption='Confirmation Rate' datatype='real' name='[Calculation_2285907838005274]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Confirmed&apos; THEN [Booking_ID] END) / COUNT([Booking_ID])' />
            </column>
            <column caption='Current Month Bookings' datatype='integer' name='[Calculation_2285908035452961]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Booking_ID] END) }' />
            </column>
            <column caption='Previous Month Bookings' datatype='integer' name='[Calculation_2285908035665954]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Booking_ID] END) }' />
            </column>
            <column caption='Bookings MoM %' datatype='real' name='[Calculation_2285908036014115]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_2285908035452961] - [Calculation_2285908035665954]) / [Calculation_2285908035665954]' />
            </column>
            <column caption='Current Month Average Fare' datatype='real' name='[Calculation_2285908036091940]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Fare_Amount] END) &#13;&#10;     / &#13;&#10;     COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Booking_ID] END) }' />
            </column>
            <column caption='Previous Month Average Fare' datatype='real' name='[Calculation_2285908036231205]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Fare_Amount] END) &#13;&#10;     / &#13;&#10;     COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Booking_ID] END) }' />
            </column>
            <column caption='Average Fare MoM %' datatype='real' name='[Calculation_2285908036300838]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_2285908036091940] - [Calculation_2285908036231205]) / [Calculation_2285908036231205]' />
            </column>
            <column caption='Cancelled Bookings' datatype='integer' name='[Calculation_2285908052799532]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Cancelled&apos; THEN [Booking_ID] END)' />
            </column>
            <column datatype='integer' name='[Capacity]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Customer ID' datatype='integer' name='[Customer_ID]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Destination]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Distance]' role='measure' type='quantitative' />
