    <worksheet name='Overview Sheet 16'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#054a75' fontname='Consolas,Courier New,monospace' fontsize='12'>Bookings by Lead Time</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bus_booking_tableau' name='federated.1y61ql410mslgw1gnubr30hxnqf6' />
          </datasources>
          <datasource-dependencies datasource='federated.1y61ql410mslgw1gnubr30hxnqf6'>
            <column caption='Booking Date' datatype='date' name='[Booking_Date]' role='dimension' type='ordinal' />
            <column caption='Booking ID' datatype='integer' name='[Booking_ID]' role='dimension' type='ordinal' />
            <column caption='Lead Time Group' datatype='string' name='[Calculation_1002228312547338]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2285907836002308] = 0 THEN &quot;Same Day&quot;&#13;&#10;ELSEIF [Calculation_2285907836002308] &gt;= 1 AND [Calculation_2285907836002308] &lt;= 3 THEN &quot;1-3 Days&quot;&#13;&#10;ELSEIF [Calculation_2285907836002308] &gt;= 4 AND [Calculation_2285907836002308] &lt;= 7 THEN &quot;4-7 Days&quot;&#13;&#10;ELSE &quot;8+ Days&quot;&#13;&#10;END' />
            </column>
            <column caption='avg(0)' datatype='real' name='[Calculation_1002228312801292]' role='measure' type='quantitative' user:unnamed='Sheet 16'>
              <calculation class='tableau' formula='avg(0)' />
            </column>
            <column caption='Total Bookings' datatype='integer' name='[Calculation_2285907835752449]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Booking_ID])' />
            </column>
            <column caption='Lead Time Days' datatype='integer' name='[Calculation_2285907836002308]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Booking_Date], [Travel_Date])' />
            </column>
            <column caption='Travel Date' datatype='date' name='[Travel_Date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1002228312547338]' derivation='None' name='[none:Calculation_1002228312547338:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1002228312801292]' derivation='User' name='[usr:Calculation_1002228312801292:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2285907835752449]' derivation='User' name='[usr:Calculation_2285907835752449:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
