        <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Fare_Amount] END) &#13;&#10;     / &#13;&#10;     COUNT(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Booking_ID] END) }' />
