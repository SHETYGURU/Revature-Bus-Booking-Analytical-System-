      <aliases enabled='yes' />
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='Booking Date' datatype='date' name='[Booking_Date]' role='dimension' type='ordinal' />
      <column caption='Booking ID' datatype='integer' name='[Booking_ID]' role='dimension' type='ordinal' />
      <column caption='Booking Status' datatype='string' name='[Booking_Status]' role='dimension' type='nominal' />
      <column aggregation='Sum' caption='Bus ID (buses)' datatype='integer' name='[Bus_ID (buses)]' role='dimension' type='ordinal' />
      <column aggregation='Sum' caption='Bus ID' datatype='integer' name='[Bus_ID]' role='dimension' type='ordinal' />
      <column caption='Bus Number' datatype='string' name='[Bus_Number]' role='dimension' type='nominal' />
      <column caption='Bus Type' datatype='string' name='[Bus_Type]' role='dimension' type='nominal' />
      <column caption='Occupied Angle' datatype='real' name='[Calculation_1002228290994177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2285907836276743] * 180' />
      </column>
      <column caption='Unoccupied Angle' datatype='real' name='[Calculation_1002228292497410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(1.0 - [Calculation_2285907836276743]) * 180' />
      </column>
      <column caption='Semicircle Spacer' datatype='integer' name='[Calculation_1002228292661251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='180' />
      </column>
      <column caption='Left Occupied' datatype='real' name='[Calculation_1002228303269894]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_2285907836276743] &gt;= 0.5 THEN 90&#13;&#10;ELSE [Calculation_2285907836276743] * 2 * 90&#13;&#10;END' />
      </column>
      <column caption='Left Unoccupied' datatype='real' name='[Calculation_1002228303331335]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='90 - [Calculation_1002228303269894]' />
      </column>
      <column caption='Right Occupied' datatype='real' name='[Calculation_1002228303392776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_2285907836276743] &lt;= 0.5 THEN 0&#13;&#10;ELSE ([Calculation_2285907836276743] - 0.5) * 2 * 90&#13;&#10;END' />
      </column>
      <column caption='Right Unoccupied' datatype='real' name='[Calculation_1002228303474697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='90 - [Calculation_1002228303392776]' />
      </column>
      <column caption='Lead Time Group' datatype='string' name='[Calculation_1002228312547338]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2285907836002308] = 0 THEN &quot;Same Day&quot;&#13;&#10;ELSEIF [Calculation_2285907836002308] &gt;= 1 AND [Calculation_2285907836002308] &lt;= 3 THEN &quot;1-3 Days&quot;&#13;&#10;ELSEIF [Calculation_2285907836002308] &gt;= 4 AND [Calculation_2285907836002308] &lt;= 7 THEN &quot;4-7 Days&quot;&#13;&#10;ELSE &quot;8+ Days&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_2285907835625472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount])' />
      </column>
      <column caption='Total Bookings' datatype='integer' name='[Calculation_2285907835752449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Booking_ID])' />
      </column>
      <column caption='Average Fare' datatype='real' name='[Calculation_2285907835834370]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNT([Booking_ID])' />
      </column>
      <column caption='Unique Customers' datatype='integer' name='[Calculation_2285907835920387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer_ID])' />
      </column>
      <column caption='Lead Time Days' datatype='integer' name='[Calculation_2285907836002308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Booking_Date], [Travel_Date])' />
      </column>
      <column caption='Average Lead Time' datatype='real' name='[Calculation_2285907836092421]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_2285907836002308])' />
      </column>
      <column caption=' Customer Retention Rate' datatype='real' name='[Calculation_2285907836186630]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF { FIXED [Customer_ID] : COUNT([Booking_ID]) } &gt; 1 THEN [Customer_ID] END) &#13;&#10;/ &#13;&#10;COUNTD([Customer_ID])' />
      </column>
      <column caption='Occupancy Rate' datatype='real' name='[Calculation_2285907836276743]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Booking_ID] END)&#13;&#10;/&#13;&#10;SUM({ FIXED [Travel_Date], [Bus_ID] : MAX([Capacity]) })' />
      </column>
      <column caption='Cancellation Rate' datatype='real' name='[Calculation_2285907836370952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Cancelled&apos; THEN [Booking_ID] END) / COUNT([Booking_ID])' />
      </column>
      <column caption='Revenue Leakage' datatype='real' name='[Calculation_2285907836481545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Booking_Status] = &apos;Cancelled&apos; THEN [Fare_Amount] END)' />
      </column>
      <column caption='Active Route Footprint' datatype='integer' name='[Calculation_2285907836579850]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Route_ID])' />
      </column>
      <column caption='Total Buses' datatype='integer' name='[Calculation_2285907836706827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Bus_ID])' />
      </column>
      <column caption='Total Seating Capacity' datatype='integer' name='[Calculation_2285907836796940]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Capacity])' />
      </column>
      <column caption='Occupied Seats' datatype='integer' name='[Calculation_2285907836858381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Booking_ID] END)' />
      </column>
      <column caption='Average Bus Capacity' datatype='real' name='[Calculation_2285907836948494]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Capacity])' />
      </column>
      <column caption='Net Realized Revenue' datatype='real' name='[Calculation_2285907837034511]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Fare_Amount] END)' />
      </column>
      <column caption='Avg Bookings per Customer' datatype='real' name='[Calculation_2285907837124624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Booking_ID]) / COUNTD([Customer_ID])' />
      </column>
      <column caption='Avg Spend per Customer' datatype='real' name='[Calculation_2285907837206545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Customer_ID])' />
      </column>
      <column caption='Total Distance Covered' datatype='integer' name='[Calculation_2285907837325330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Distance])' />
      </column>
      <column caption='Average Route Distance' datatype='real' name='[Calculation_2285907837423635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Distance])' />
      </column>
      <column caption='Revenue per KM' datatype='real' name='[Calculation_2285907837493268]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount]) / SUM([Distance])' />
      </column>
      <column caption='Successful Transactions' datatype='integer' name='[Calculation_2285907837562901]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Confirmed&apos; THEN [Booking_ID] END)' />
      </column>
      <column caption='Avg Route Yield' datatype='real' name='[Calculation_2285907837657110]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Route_ID])' />
      </column>
      <column caption='Avg Revenue per Day' datatype='real' name='[Calculation_2285907837751319]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare_Amount]) / COUNTD([Booking_Date])' />
      </column>
      <column caption='Loyal Customers' datatype='integer' name='[Calculation_2285907837833240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF { FIXED [Customer_ID] : COUNT([Booking_ID]) } &gt;= 2 THEN [Customer_ID] END)' />
      </column>
      <column caption='Average Confirmed Transaction Value' datatype='real' name='[Calculation_2285907837915161]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Booking_Status] &lt;&gt; &apos;Cancelled&apos; THEN [Fare_Amount] END) / COUNT(IF [Booking_Status] = &apos;Confirmed&apos; THEN [Booking_ID] END)' />
      </column>
      <column caption='Confirmation Rate' datatype='real' name='[Calculation_2285907838005274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Confirmed&apos; THEN [Booking_ID] END) / COUNT([Booking_ID])' />
      </column>
      <column caption='Pending Rate' datatype='real' name='[Calculation_2285907838144539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Booking_Status] = &apos;Pending&apos; THEN [Booking_ID] END) / COUNT([Booking_ID])' />
      </column>
      <column caption='Current Month Revenue' datatype='real' name='[Calculation_2285907838828573]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = [Parameters].[Parameter 2285907838521372] THEN [Fare_Amount] END) }' />
      </column>
      <column caption='Previous Month Revenue' datatype='real' name='[Calculation_2285907838926878]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF DATETRUNC(&apos;month&apos;, [Booking_Date]) = DATEADD(&apos;month&apos;, -1, [Parameters].[Parameter 2285907838521372]) THEN [Fare_Amount] END) }' />
      </column>
      <column caption='Revenue MoM %' datatype='real' name='[Calculation_2285907839029279]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2285907838828573] - [Calculation_2285907838926878]) / [Calculation_2285907838926878]' />
      </column>
      <column caption='Current Month Bookings' datatype='integer' name='[Calculation_2285908035452961]' role='measure' type='quantitative'>
