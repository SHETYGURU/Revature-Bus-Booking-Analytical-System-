          <style-rule element='axis'>
            <encoding attr='space' class='1' field='[federated.1y61ql410mslgw1gnubr30hxnqf6].[usr:Calculation_1002228312801292:qk]' field-type='quantitative' fold='true' scope='rows' type='space' />
